// Kinaxis clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace kinaxis {

    entity Catalog {
        id: string @unique
        name: string
        supplierId: string
        itemCount: integer
        createdAt: datetime
        updatedAt: datetime
    }

    entity Product {
        id: string @unique
        sku: string
        title: string
        price: float
        currency: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Requisition {
        id: string @unique
        requesterId: string
        total: float
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity PurchaseOrder {
        id: string @unique
        supplierId: string
        total: float
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Supplier {
        id: string @unique
        name: string
        taxId: string
        rating: float
        createdAt: datetime
        updatedAt: datetime
    }

    entity Invoice {
        id: string @unique
        supplierId: string
        poId: string
        total: float
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
